datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Showroom {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  contact   String
  location  String
  image     String[]
  cars      Car[]
  createdat DateTime @default(now()) @map("createdat")

  @@map("showroom")
}

model Car {
  id           String    @id @default(uuid())
  brand        String
  model        String
  category     String?
  priceperday  Float
  seats        Int       @default(5)
  enginepower  String?
  maxspeed     String?
  fueltype     String?
  color        String?
  description  String?
  images       String[]
  registration String?
  features     String[]
  showroom     Showroom  @relation(fields: [showroomid], references: [id])
  showroomid   String
  reviews      Review[]
  bookings     Booking[]
  isavailable  Boolean   @default(true)
  location     String?
  rating       Float     @default(5.0)
  reviewcount  Int       @default(0)
  createdat    DateTime  @default(now()) @map("createdat")

  @@map("car")
}

model Review {
  id        String   @id @default(uuid())
  username  String
  userimage String?
  rating    Float
  comment   String
  car       Car      @relation(fields: [carid], references: [id])
  carid     String
  createdat DateTime @default(now()) @map("createdat")

  @@map("review")
}

model Booking {
  id            String   @id @default(uuid())
  customername  String
  customeremail String
  customerphone String
  gender        String?
  pickupdate    String
  returndate    String
  totalamount   Float
  withdriver    Boolean  @default(false)
  status        String   @default("PENDING")
  car           Car      @relation(fields: [carid], references: [id])
  carid         String
  userid        String?
  createdat     DateTime @default(now()) @map("createdat")

  @@map("booking")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  @@map("users")
}

model Favorite {
  id      String @id @default(uuid())
  user_id String
  car_id  String

  @@map("favorites")
}
