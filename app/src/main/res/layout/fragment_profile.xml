<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/white">

            <!-- Profile Info Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile_avatar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/group"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImage"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/iv_profile_avatar"
                    android:layout_marginStart="16dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/tv_profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Benjamin Jack"
                        android:fontFamily="@font/urbanist_bold"
                        android:textSize="18sp"
                        android:textColor="@color/onBackground"/>

                    <TextView
                        android:id="@+id/tv_profile_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="benjaminJack@gmail.com"
                        android:fontFamily="@font/urbanist_regular"
                        android:textSize="14sp"
                        android:textColor="@color/gray_text"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/edit"
                        app:tint="@color/gray_text"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit profile"
                        android:textSize="12sp"
                        android:textColor="@color/gray_text"/>
                </LinearLayout>

            </RelativeLayout>

            <!-- General Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="General"
                android:fontFamily="@font/urbanist_bold"
                android:textColor="@color/onBackground"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <!-- Fav Cars Row -->
            <LinearLayout
                android:id="@+id/row_fav_cars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="5dp">
                
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/heart"
                    android:background="@drawable/nav_item_color"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Favorite Cars"
                    android:textColor="@color/onBackground"
                    android:fontFamily="@font/urbanist_regular"/>
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/back"
                    android:rotation="180"
                    app:tint="@color/gray_text"/>
            </LinearLayout>

            <!-- Previous Rent Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="5dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/rent"
                    android:background="@drawable/nav_item_color"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Previous Rent"
                    android:textColor="@color/onBackground"
                    android:fontFamily="@font/urbanist_regular"/>
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/back"
                    android:rotation="180"
                    app:tint="@color/gray_text"/>
            </LinearLayout>

            <!-- Support Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Support"
                android:fontFamily="@font/urbanist_bold"
                android:textColor="@color/onBackground"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"/>

            <!-- Settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="5dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/customersupport"
                    android:background="@drawable/nav_item_color"
                    android:padding="8dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Settings"
                    android:textColor="@color/onBackground"
                    android:fontFamily="@font/urbanist_regular"/>
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/back"
                    android:rotation="180"
                    app:tint="@color/gray_text"/>
            </LinearLayout>

            <!-- Login/Log out Row -->
            <LinearLayout
                android:id="@+id/row_auth_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="5dp">
                <ImageView
                    android:id="@+id/iv_auth_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/quit"
                    android:background="@drawable/nav_item_color"
                    android:padding="8dp"/>
                <TextView
                    android:id="@+id/tv_auth_action"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Log out"
                    android:textColor="@color/onBackground"
                    android:fontFamily="@font/urbanist_regular"/>
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/back"
                    android:rotation="180"
                    app:tint="@color/gray_text"/>
            </LinearLayout>

            <!-- Become Partner Button -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_become_partner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/black"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Want to become partner?"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"

                            android:fontFamily="@font/urbanist_bold"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="List your cars for rent"
                            android:textColor="#B3FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/urbanist_regular" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_become_partner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Join"
                        android:textColor="@android:color/black"
                        android:backgroundTint="@android:color/white"
                        android:fontFamily="@font/urbanist_bold"
                        android:textSize="14sp"
                        app:strokeWidth="0dp"
                        app:cornerRadius="14dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>