<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider"
    app:cardElevation="0dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Car Image + Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_booking_car_image"
                android:layout_width="80dp"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:src="@drawable/car_image" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_booking_car_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Car Name"
                    android:textSize="16sp"
                    android:fontFamily="@font/urbanist_bold"
                    android:textColor="@color/onBackground" />

                <TextView
                    android:id="@+id/tv_booking_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PKR 25,000"
                    android:textSize="14sp"
                    android:fontFamily="@font/urbanist_bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tv_booking_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textSize="11sp"
                android:fontFamily="@font/urbanist_bold"
                android:textColor="@color/white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_chip_selected" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider" />

        <!-- Date Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pickup"
                    android:textSize="11sp"
                    android:fontFamily="@font/urbanist_regular"
                    android:textColor="@color/gray_text" />

                <TextView
                    android:id="@+id/tv_booking_pickup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01 Jan 2025"
                    android:textSize="13sp"
                    android:fontFamily="@font/urbanist_bold"
                    android:textColor="@color/onBackground" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Return"
                    android:textSize="11sp"
                    android:fontFamily="@font/urbanist_regular"
                    android:textColor="@color/gray_text" />

                <TextView
                    android:id="@+id/tv_booking_return"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="05 Jan 2025"
                    android:textSize="13sp"
                    android:fontFamily="@font/urbanist_bold"
                    android:textColor="@color/onBackground" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver"
                    android:textSize="11sp"
                    android:fontFamily="@font/urbanist_regular"
                    android:textColor="@color/gray_text" />

                <TextView
                    android:id="@+id/tv_booking_driver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No"
                    android:textSize="13sp"
                    android:fontFamily="@font/urbanist_bold"
                    android:textColor="@color/onBackground" />
            </LinearLayout>
        </LinearLayout>

        <!-- Cancel Button (only for PENDING) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_booking"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/surface"
            android:fontFamily="@font/urbanist_bold"
            android:text="Cancel Booking"
            android:textAllCaps="false"
            android:textColor="@color/onBackground"
            android:textSize="13sp"
            android:visibility="gone"
            app:cornerRadius="12dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
